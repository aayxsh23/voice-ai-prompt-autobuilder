# =====================================================================
# VOICE AGENT PROMPT BUILDER - ENVIRONMENT CONFIGURATION
# =====================================================================

# 1. LOCAL SQLITE DATABASE CONNECTION
# Must point to your local dev.db file. Do not use PostgreSQL or Supabase.
DATABASE_URL="file:./dev.db"

# 2. LLM PROVIDER ROUTING SWITCH
# Options: 'mock' | 'gemini'
# - 'mock': Uses deterministic, high-fidelity local generation rules (No API key needed)
# - 'gemini': Uses Google GenAI SDK (@google/genai) with self-critique loop
LLM_PROVIDER="mock"

# 3. GOOGLE GEMINI API KEY
# Required if LLM_PROVIDER="gemini". If missing, the app automatically falls back to mock mode.
GEMINI_API_KEY="AIzaSy...your_gemini_api_key_here..."

# 4. NEXT.JS APP SETTINGS
NEXT_PUBLIC_APP_URL="http://localhost:3000"
